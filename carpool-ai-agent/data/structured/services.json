{
  "service_definitions": {
    "user_service": {
      "endpoints": [
        "POST /users/register",
        "POST /users/login",
        "GET /users/{id}",
        "PUT /users/{id}/profile",
        "GET /users/{id}/preferences",
        "PUT /users/{id}/preferences"
      ],
      "auth_required": true,
      "rate_limit": "1000 req/min"
    },
    "ride_service": {
      "endpoints": [
        "POST /rides/create",
        "GET /rides/available",
        "GET /rides/{id}",
        "PUT /rides/{id}/status",
        "POST /rides/{id}/request",
        "POST /rides/{id}/cancel"
      ],
      "auth_required": true,
      "rate_limit": "500 req/min"
    },
    "matching_service": {
      "endpoints": [
        "POST /match/find-ride",
        "POST /match/backup-assignment",
        "GET /match/history/{user_id}",
        "POST /match/ai-recommendation"
      ],
      "auth_required": true,
      "rate_limit": "2000 req/min"
    },
    "payment_service": {
      "endpoints": [
        "POST /payments/process",
        "GET /payments/{id}",
        "POST /payments/{id}/refund",
        "GET /payments/invoice/{ride_id}"
      ],
      "auth_required": true,
      "rate_limit": "100 req/min",
      "pci_compliance": true
    },
    "notification_service": {
      "endpoints": [
        "POST /notifications/send",
        "GET /notifications/{user_id}",
        "PUT /notifications/{id}/read",
        "POST /notifications/preferences"
      ],
      "auth_required": true,
      "rate_limit": "5000 req/min"
    }
  },
  "integration_points": {
    "google_maps": {
      "service": "Route optimization, distance calculation",
      "auth": "API key"
    },
    "stripe": {
      "service": "Payment processing",
      "auth": "API key"
    },
    "sendgrid": {
      "service": "Email notifications",
      "auth": "API key"
    },
    "auth0": {
      "service": "User authentication",
      "auth": "OAuth2"
    }
  }
}

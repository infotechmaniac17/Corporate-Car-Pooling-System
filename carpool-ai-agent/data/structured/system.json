{
  "microservices": [
    {
      "name": "User Service",
      "port": 5001,
      "responsibilities": ["User authentication", "Profile management", "Preferences"],
      "database": "PostgreSQL"
    },
    {
      "name": "Ride Service",
      "port": 5002,
      "responsibilities": ["Ride creation", "Ride management", "Ride scheduling"],
      "database": "PostgreSQL"
    },
    {
      "name": "Matching Service",
      "port": 5003,
      "responsibilities": ["AI-powered ride matching", "Route optimization", "Backup ride assignment"],
      "database": "PostgreSQL + Vector DB"
    },
    {
      "name": "Payment Service",
      "port": 5004,
      "responsibilities": ["Payment processing", "Invoice generation", "Refunds"],
      "database": "PostgreSQL"
    },
    {
      "name": "Notification Service",
      "port": 5005,
      "responsibilities": ["Email notifications", "SMS alerts", "Push notifications"],
      "database": "Redis"
    },
    {
      "name": "Analytics Service",
      "port": 5006,
      "responsibilities": ["Usage analytics", "Cost tracking", "CO2 savings calculation"],
      "database": "InfluxDB"
    }
  ],
  "api_gateway": {
    "port": 8000,
    "technology": "Kong/FastAPI",
    "features": ["Rate limiting", "Authentication", "Request routing"]
  },
  "frontend": {
    "technology": "React + TypeScript",
    "frameworks": ["Next.js", "Tailwind CSS"],
    "features": ["Landing page", "Dashboard", "Ride booking", "Profile management"]
  },
  "external_services": [
    "Google Maps API",
    "Stripe/PayPal",
    "SendGrid",
    "AWS S3",
    "Auth0"
  ],
  "key_technologies": [
    "Python/FastAPI",
    "PostgreSQL",
    "Redis",
    "Docker",
    "Kubernetes",
    "React",
    "LangGraph",
    "Claude API",
    "FAISS Vector Store"
  ]
}
